---
import { CF_IMAGE_PRESETS, getCFImageUrl } from '../../utils/cloudflare-images'

interface DirectoryItem {
  href: string
  name: string
  image: string | null
  imageAlt: string
  kicker?: string
  meta: string
  detail?: string
}

interface Props {
  groups: Array<[string, DirectoryItem[]]>
}

const { groups } = Astro.props
const imagePreset = CF_IMAGE_PRESETS.tunesDirectory

const getInitial = (name: string) =>
  name.replace(/^the\s+/i, '').trim().charAt(0).toUpperCase() || '#'

const getImageSrcSet = (src: string) =>
  imagePreset.widths
    .map((width) => `${getCFImageUrl(src, {
      width,
      height: width,
      quality: imagePreset.quality,
      format: imagePreset.format,
      fit: imagePreset.fit,
      gravity: 'auto'
    })} ${width}w`)
    .join(', ')
---

<nav
  aria-label="Jump to letter"
  class="surface-container-lowest rounded-xl p-4 mb-8 flex flex-wrap gap-2 justify-center shadow-ambient"
>
  {groups.map(([letter]) => (
    <a
      href={`#letter-${letter}`}
      class="font-display text-sm font-semibold rounded-full px-3 py-1 surface-container hover:bg-[var(--color-surface-container-high)] transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-blue-500/50"
    >
      {letter}
    </a>
  ))}
</nav>

{groups.map(([letter, list]) => (
  <section id={`letter-${letter}`} class="mb-10 scroll-mt-24">
    <h2 class="font-display text-3xl font-bold mb-4 text-on-surface">{letter}</h2>
    <ul class="grid grid-cols-1 lg:grid-cols-2 gap-3 md:gap-4">
      {list.map((item) => (
        <li class="min-w-0">
          <a
            href={item.href}
            class="group flex min-w-0 min-h-[96px] overflow-hidden surface-container-lowest rounded-xl shadow-ambient transition-all duration-300 hover:-translate-y-[2px] hover:shadow-[0_12px_32px_rgba(25,28,29,0.08)] focus:outline-none focus-visible:ring-4 focus-visible:ring-blue-500/50"
          >
            <div class="relative w-[84px] sm:w-[96px] shrink-0 overflow-hidden surface-container">
              <div class="absolute inset-0 flex items-center justify-center bg-[linear-gradient(135deg,var(--color-surface-container),var(--color-surface-container-high))] font-display text-3xl font-bold text-on-surface-variant opacity-50" aria-hidden="true">
                {getInitial(item.name)}
              </div>
              {item.image && (
                <img
                  src={getCFImageUrl(item.image, {
                    width: 160,
                    height: 160,
                    quality: imagePreset.quality,
                    format: imagePreset.format,
                    fit: imagePreset.fit,
                    gravity: 'auto'
                  })}
                  srcset={getImageSrcSet(item.image)}
                  sizes="(min-width: 640px) 96px, 84px"
                  alt={item.imageAlt}
                  width="160"
                  height="160"
                  loading="lazy"
                  decoding="async"
                  fetchpriority="low"
                  onerror="this.style.display = 'none'"
                  class="absolute inset-0 h-full w-full object-cover transition-transform duration-500 group-hover:scale-[1.04]"
                />
              )}
            </div>
            <div class="min-w-0 flex flex-1 flex-col justify-center p-4">
              {item.kicker && (
                <span class="mb-1 block truncate text-xs font-semibold uppercase tracking-wide text-[var(--color-secondary)]">
                  {item.kicker}
                </span>
              )}
              <span class="font-display text-base font-semibold leading-snug text-on-surface line-clamp-2 transition-colors group-hover:text-[var(--color-primary)]">
                {item.name}
              </span>
              <span class="mt-1 text-sm text-on-surface-variant leading-snug">
                {item.meta}
              </span>
              {item.detail && (
                <span class="mt-2 text-xs text-on-surface-variant opacity-80 line-clamp-1">
                  {item.detail}
                </span>
              )}
            </div>
          </a>
        </li>
      ))}
    </ul>
  </section>
))}
