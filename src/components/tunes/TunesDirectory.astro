---
import { CF_IMAGE_PRESETS, getCFImageUrl } from '../../utils/cloudflare-images'

interface DirectoryItem {
  href: string
  name: string
  image: string | null
  imageAlt: string
  kicker?: string
  meta: string
  detail?: string
}

interface Props {
  groups: Array<[string, DirectoryItem[]]>
}

const { groups } = Astro.props
const imagePreset = CF_IMAGE_PRESETS.tunesDirectory

const getInitial = (name: string) =>
  name.replace(/^the\s+/i, '').trim().charAt(0).toUpperCase() || '#'

const getImageSrcSet = (src: string) =>
  imagePreset.widths
    .map((width) => `${getCFImageUrl(src, {
      width,
      height: width,
      quality: imagePreset.quality,
      format: imagePreset.format,
      fit: imagePreset.fit,
      gravity: 'auto'
    })} ${width}w`)
    .join(', ')
---

<nav
  aria-label="Jump to letter"
  class="mb-10 pb-4 border-b flex flex-wrap gap-x-4 gap-y-2"
  style="border-color: var(--color-outline-variant);"
>
  {groups.map(([letter]) => (
    <a
      href={`#letter-${letter}`}
      class="rubric nav-underline no-underline hover:text-on-surface"
    >
      {letter}
    </a>
  ))}
</nav>

{groups.map(([letter, list]) => (
  <section id={`letter-${letter}`} class="mb-12 scroll-mt-24">
    <h2 class="font-display text-3xl mb-2 pb-2 border-b text-on-surface" style="border-color: var(--color-outline-variant);">{letter}</h2>
    <ul class="grid grid-cols-1 lg:grid-cols-2 gap-x-8">
      {list.map((item) => (
        <li class="min-w-0 border-b" style="border-color: var(--color-outline-variant);">
          <a
            href={item.href}
            class="group flex min-w-0 min-h-[96px] overflow-hidden py-3 no-underline focus:outline-none focus-visible:outline-2 focus-visible:outline-offset-4"
          >
            <div class="relative w-[84px] sm:w-[96px] shrink-0 overflow-hidden border" style="border-color: var(--color-outline-variant);">
              <div class="absolute inset-0 flex items-center justify-center surface-container font-display text-3xl text-on-surface-variant opacity-50" aria-hidden="true">
                {getInitial(item.name)}
              </div>
              {item.image && (
                <img
                  src={getCFImageUrl(item.image, {
                    width: 160,
                    height: 160,
                    quality: imagePreset.quality,
                    format: imagePreset.format,
                    fit: imagePreset.fit,
                    gravity: 'auto'
                  })}
                  srcset={getImageSrcSet(item.image)}
                  sizes="(min-width: 640px) 96px, 84px"
                  alt={item.imageAlt}
                  width="160"
                  height="160"
                  loading="lazy"
                  decoding="async"
                  fetchpriority="low"
                  onerror="this.style.display = 'none'"
                  class="absolute inset-0 h-full w-full object-cover transition-transform duration-500 group-hover:scale-[1.04]"
                />
              )}
            </div>
            <div class="min-w-0 flex flex-1 flex-col justify-center p-4">
              {item.kicker && (
                <span class="rubric mb-1 block truncate text-xs" style="color: var(--color-secondary);">
                  {item.kicker}
                </span>
              )}
              <span class="font-display text-base leading-snug text-on-surface line-clamp-2 transition-colors group-hover:text-[var(--color-secondary)]" style="font-weight: 660;">
                {item.name}
              </span>
              <span class="mt-1 text-sm text-on-surface-variant leading-snug">
                {item.meta}
              </span>
              {item.detail && (
                <span class="mt-2 text-xs text-on-surface-variant opacity-80 line-clamp-1">
                  {item.detail}
                </span>
              )}
            </div>
          </a>
        </li>
      ))}
    </ul>
  </section>
))}
