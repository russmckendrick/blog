---
import { NAVIGATION_ITEMS, AUTHOR_NAME } from '../../consts';
import Icon from '../ui/Icon.astro';

const today = new Date();
---

<footer class="surface-container-low mt-20" transition:name="site-footer">
	<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
		<div class="flex flex-col items-center">
			<div class="text-center text-sm text-on-surface-variant">
				<p class="flex flex-wrap items-center justify-center gap-x-2 gap-y-1">
					<span>&copy; {today.getFullYear()} {AUTHOR_NAME}. All rights reserved.</span>
					<span class="hidden sm:inline">|</span>
					<span class="flex flex-wrap items-center justify-center gap-x-3 gap-y-1">
						{NAVIGATION_ITEMS.map((item) => (
							<a
								href={item.url}
								class="inline-flex items-center gap-1.5 px-1 py-0.5 text-on-surface-variant hover:text-on-surface underline-offset-4 hover:underline transition-colors"
								target={item.external ? '_blank' : undefined}
								rel={item.external ? 'noopener noreferrer' : undefined}
							>
								<Icon name={item.icon} size={14} />
								{item.name}
							</a>
						))}
					</span>
				</p>
			</div>
		</div>
	</div>
</footer>
