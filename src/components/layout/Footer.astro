---
import { NAVIGATION_ITEMS, AUTHOR_NAME } from '../../consts';

const today = new Date();
---

<footer class="mt-16 border-t" style="border-color: var(--color-outline-variant);" transition:name="site-footer">
	<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
		<div class="flex flex-col items-center gap-4">
			<nav aria-label="Footer navigation">
				<ul class="flex flex-wrap items-center justify-center gap-x-5 gap-y-2">
					{NAVIGATION_ITEMS.map((item) => (
						<li>
							<a
								href={item.url}
								class="rubric nav-underline no-underline py-0.5 hover:text-on-surface"
								target={item.external ? '_blank' : undefined}
								rel={item.external ? 'noopener noreferrer' : undefined}
							>
								{item.name}
							</a>
						</li>
					))}
				</ul>
			</nav>
			<p class="text-center text-sm text-on-surface-variant italic">
				&copy; {today.getFullYear()} {AUTHOR_NAME} &middot; Set in Fraunces &amp; Source Serif
			</p>
		</div>
	</div>
</footer>
