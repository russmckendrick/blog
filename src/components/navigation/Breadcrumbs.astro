---
interface BreadcrumbItem {
  label: string;
  url: string;
}

interface Props {
  items: BreadcrumbItem[];
}

const { items } = Astro.props;

// Generate breadcrumb schema
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": items.map((item, index) => ({
    "@type": "ListItem",
    "position": index + 1,
    "name": item.label,
    "item": new URL(item.url, Astro.site).toString()
  }))
};
---

<nav aria-label="Breadcrumb" class="mb-3">
  <ol class="flex items-center gap-2 rubric">
    {items.map((item, index) => (
      <li class="flex items-center gap-2 min-w-0">
        {index > 0 && <span aria-hidden="true" style="color: var(--color-outline-variant);">/</span>}
        {index === items.length - 1 ? (
          <span class="truncate text-on-surface-variant">{item.label}</span>
        ) : (
          <a href={item.url} class="nav-underline no-underline text-on-surface-variant hover:text-on-surface transition-colors">
            {item.label}
          </a>
        )}
      </li>
    ))}
  </ol>
</nav>

<script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
