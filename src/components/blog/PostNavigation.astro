---
import type { CollectionEntry } from 'astro:content'
import { getPostUrl } from '../../utils/url.ts'

type PostEntry = CollectionEntry<'blog'> | CollectionEntry<'tunes'>

interface Props {
  previousPost?: PostEntry
  nextPost?: PostEntry
}

const { previousPost, nextPost } = Astro.props
---

{(previousPost || nextPost) && (
  <nav aria-label="Post navigation" class="mt-10 pt-5 border-t" style="border-color: var(--color-outline-variant);">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 md:gap-8">
      {previousPost && (
        <a
          href={getPostUrl(previousPost.data.pubDate, previousPost.data.title)}
          class="group flex flex-col gap-1 no-underline focus:outline-none focus-visible:outline-2 focus-visible:outline-offset-4"
        >
          <span class="rubric">&larr; Previous</span>
          <span class="font-display text-lg text-on-surface line-clamp-1 transition-colors group-hover:text-[var(--color-secondary)]" style="font-weight: 660;">
            {previousPost.data.title}
          </span>
        </a>
      )}

      {nextPost && (
        <a
          href={getPostUrl(nextPost.data.pubDate, nextPost.data.title)}
          class:list={[
            "group flex flex-col gap-1 items-end text-right no-underline focus:outline-none focus-visible:outline-2 focus-visible:outline-offset-4",
            !previousPost && "md:col-start-2"
          ]}
        >
          <span class="rubric">Next &rarr;</span>
          <span class="font-display text-lg text-on-surface line-clamp-1 transition-colors group-hover:text-[var(--color-secondary)]" style="font-weight: 660;">
            {nextPost.data.title}
          </span>
        </a>
      )}
    </div>
  </nav>
)}
