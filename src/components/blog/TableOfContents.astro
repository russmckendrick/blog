---
export interface Heading {
  depth: number;
  text: string;
  slug: string;
}

interface Props {
  headings: Heading[];
}

const { headings } = Astro.props;

// Filter to only show h2 and h3 headings
const tocHeadings = headings.filter(h => h.depth <= 3);
---

{tocHeadings.length > 0 && (
  <nav class="toc-wrapper mb-10">
    <details class="group surface-container-low rounded-xl shadow-ambient" id="toc-details">
      <summary class="toc-summary cursor-pointer select-none px-6 py-4 font-semibold flex items-center justify-between rounded-xl transition-colors">
        <span class="flex items-center gap-2">
          <svg class="toc-icon w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h7"></path>
          </svg>
          Table of Contents
        </span>
        <svg class="toc-chevron w-5 h-5 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
        </svg>
      </summary>
      <div class="px-6 pb-5 pt-1">
        <ol class="toc-list">
          {tocHeadings.map((heading) => (
            <li>
              <a
                href={`#${heading.slug}`}
                class:list={[
                  'toc-link',
                  { 'toc-link--nested': heading.depth === 3 }
                ]}
              >
                {heading.text}
              </a>
            </li>
          ))}
        </ol>
      </div>
    </details>
  </nav>
)}

<style>
  .toc-summary {
    color: var(--color-on-surface);
  }

  .toc-summary:hover {
    background: var(--color-surface-container);
  }

  .toc-icon {
    color: var(--color-secondary);
  }

  .toc-chevron {
    color: var(--color-on-surface-variant);
  }

  .toc-list {
    list-style: none;
    padding: 0;
    margin: 0;
    border-left: 1px solid var(--color-surface-container-high);
  }

  .toc-link {
    display: block;
    font-size: 0.875rem;
    line-height: 1.5;
    padding: 0.3rem 0.75rem;
    color: var(--color-on-surface-variant);
    text-decoration: none;
    border-left: 2px solid transparent;
    margin-left: -1px;
    transition: color 0.2s ease, border-color 0.2s ease;
  }

  .toc-link:hover {
    color: var(--color-primary);
    border-left-color: var(--color-secondary);
  }

  .toc-link--nested {
    padding-left: 1.5rem;
    font-size: 0.8125rem;
  }
</style>

<script>
  let cleanupToc: (() => void) | undefined

  function initTocState() {
    cleanupToc?.()

    requestAnimationFrame(() => {
      const details = document.getElementById('toc-details') as HTMLDetailsElement | null
      if (!details) return

      const controller = new AbortController()
      const { signal } = controller

      const savedState = localStorage.getItem('toc-open')
      if (savedState === 'true') {
        details.setAttribute('open', '')
      }

      details.addEventListener('toggle', () => {
        localStorage.setItem('toc-open', details.open.toString())
      }, { signal })

      cleanupToc = () => {
        controller.abort()
      }
    })
  }

  initTocState()
  document.addEventListener('astro:page-load', initTocState)
  document.addEventListener('astro:before-swap', () => {
    cleanupToc?.()
    cleanupToc = undefined
  })
</script>
