---
interface Props {
  totalArticles: number
  tagCounts: Map<string, number>
  activeTag?: string
  filteredCount?: number
}

const { totalArticles, tagCounts, activeTag, filteredCount } = Astro.props
const sortedTags = [...tagCounts.entries()].sort((a, b) => b[1] - a[1])
const isFiltered = !!activeTag
---

<div class="mb-10">
  <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-2 mb-2">
    <h1 class="text-3xl font-bold text-on-surface font-display">Reading List</h1>
    <p class="text-sm text-on-surface-variant">
      {isFiltered ? (
        <span>{filteredCount} of {totalArticles} articles saved on <a href="https://www.instapaper.com/p/russmckendrick" class="text-blue-600 dark:text-blue-400 hover:underline" target="_blank" rel="noopener noreferrer">Instapaper</a></span>
      ) : (
        <span>{totalArticles} articles saved on <a href="https://www.instapaper.com/p/russmckendrick" class="text-blue-600 dark:text-blue-400 hover:underline" target="_blank" rel="noopener noreferrer">Instapaper</a></span>
      )}
    </p>
  </div>
  <div class="border-b border-outline-variant mb-5"></div>

  {sortedTags.length > 0 && (
    <div class="flex flex-wrap items-center gap-2">
      <span class="text-xs font-medium text-on-surface-variant uppercase tracking-wider mr-1">Filter:</span>
      <a
        href="/reading/"
        class:list={["reading-tag-btn inline-flex items-center gap-1 px-3 py-1.5 rounded-full text-xs font-medium surface-container-high text-on-surface-variant hover:text-on-surface transition-all duration-200 cursor-pointer no-underline", { active: !isFiltered }]}
      >
        All
      </a>
      {sortedTags.map(([tag, count]) => (
        <a
          href={`/reading/tag/${encodeURIComponent(tag)}/`}
          class:list={["reading-tag-btn inline-flex items-center gap-1 px-3 py-1.5 rounded-full text-xs font-medium surface-container-high text-on-surface-variant hover:text-on-surface transition-all duration-200 cursor-pointer no-underline", { active: activeTag === tag }]}
        >
          {tag}
          <span class="opacity-60">({count})</span>
        </a>
      ))}
    </div>
  )}
</div>

<style>
  .reading-tag-btn.active {
    background-color: var(--color-secondary, #0058be);
    color: white;
  }
  .reading-tag-btn.active span {
    opacity: 0.8;
  }
</style>
