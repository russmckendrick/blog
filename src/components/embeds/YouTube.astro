---
import { YouTube as YouTubeEmbed } from '@astro-community/astro-embed-youtube';

interface Props {
  id: string;
  params?: string;
  playlabel?: string;
  posterQuality?: 'max' | 'high' | 'default' | 'low';
}

const { id, params, playlabel, posterQuality = 'max' } = Astro.props;
---

<div class="w-full aspect-video">
  <YouTubeEmbed id={id} params={params} playlabel={playlabel} posterQuality={posterQuality} class="w-full h-full" />
</div>

<style is:global>
  lite-youtube {
    max-width: 100% !important;
    width: 100% !important;
  }
</style>

<script>
  // Track YouTube play (lite-youtube swaps in the iframe on first click).
  // Delegated + bundled once, so it survives multiple embeds and View Transitions.
  document.addEventListener('click', (e) => {
    const player = (e.target as HTMLElement).closest('lite-youtube') as HTMLElement | null;
    if (!player || player.dataset.plausibleTracked) return;
    player.dataset.plausibleTracked = 'true';
    window.plausible?.('Video Play', { props: { provider: 'YouTube' } });
  });
</script>