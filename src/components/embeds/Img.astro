---
import { getCFImageUrl, generateCFSrcSet, CF_IMAGE_PRESETS } from '../../utils/cloudflare-images';
import { getImageDimensions } from '../../utils/image-dimensions';

interface Props {
  src: string;
  alt?: string;
  width?: string | number;
  height?: string | number;
  aspectRatio?: string;
  link?: string;
  zoom?: string | boolean;
  sizes?: string;
  fullWidth?: boolean;
}

const {
  src,
  alt = '',
  width,
  height,
  aspectRatio,
  link,
  zoom = true,
  sizes,
  fullWidth = false
} = Astro.props;

// Check if src is external URL
const isExternal = src.startsWith('http://') || src.startsWith('https://');

// Determine if zoom should be enabled
const enableZoom = zoom === 'true' || zoom === true;

// For local images, use Cloudflare Image Transformations with gallery preset
const imgSrc = isExternal ? src : getCFImageUrl(src, {
  width: 1200,
  quality: CF_IMAGE_PRESETS.gallery.quality,
  format: CF_IMAGE_PRESETS.gallery.format
});
const highResSrc = isExternal ? src : getCFImageUrl(src, {
  width: 2048,
  quality: CF_IMAGE_PRESETS.gallery.quality,
  format: CF_IMAGE_PRESETS.gallery.format,
  fit: CF_IMAGE_PRESETS.gallery.fit
});
const srcsetString = isExternal ? '' : generateCFSrcSet(
  src,
  CF_IMAGE_PRESETS.gallery.widths,
  CF_IMAGE_PRESETS.gallery.quality,
  CF_IMAGE_PRESETS.gallery.format
);

const localImageDimensions = isExternal ? null : await getImageDimensions(src);

function parseNumericDimension(value: string | number | undefined) {
  if (typeof value === 'number' && Number.isFinite(value)) {
    return value;
  }

  if (typeof value === 'string' && /^\d+(\.\d+)?$/.test(value.trim())) {
    return Number(value);
  }

  return undefined;
}

function parseAspectRatio(value: string | undefined) {
  if (!value) return undefined;

  const match = value.trim().match(/^(\d+(?:\.\d+)?)\s*\/\s*(\d+(?:\.\d+)?)$/);
  if (!match) return undefined;

  const [, widthPart, heightPart] = match;
  const widthRatio = Number(widthPart);
  const heightRatio = Number(heightPart);

  if (!Number.isFinite(widthRatio) || !Number.isFinite(heightRatio) || widthRatio <= 0 || heightRatio <= 0) {
    return undefined;
  }

  return widthRatio / heightRatio;
}

const numericWidth = parseNumericDimension(width);
const numericHeight = parseNumericDimension(height);
const numericAspectRatio = parseAspectRatio(aspectRatio);

const intrinsicWidth = localImageDimensions?.width;
const intrinsicHeight = localImageDimensions?.height;
const intrinsicAspectRatio = intrinsicWidth && intrinsicHeight ? intrinsicWidth / intrinsicHeight : undefined;
const resolvedAspectRatio = numericAspectRatio || intrinsicAspectRatio;

let resolvedWidth = numericWidth || intrinsicWidth;
let resolvedHeight = numericHeight || intrinsicHeight;

if (!resolvedHeight && resolvedWidth && resolvedAspectRatio) {
  resolvedHeight = Math.round(resolvedWidth / resolvedAspectRatio);
}

if (!resolvedWidth && resolvedHeight && resolvedAspectRatio) {
  resolvedWidth = Math.round(resolvedHeight * resolvedAspectRatio);
}

const wrapperStyle = !resolvedWidth && !resolvedHeight && aspectRatio
  ? `aspect-ratio: ${aspectRatio};`
  : undefined;

if (import.meta.env.DEV && !isExternal && !localImageDimensions && !resolvedWidth && !resolvedHeight && !aspectRatio) {
  console.warn(`[Img] Unable to determine intrinsic dimensions for ${src}. Add height and/or aspectRatio to prevent layout shift.`);
}
---

<div class={`img-wrapper mb-1 flex ${fullWidth ? '' : 'justify-center'}`} style={wrapperStyle}>
  {enableZoom ? (
    <div class={fullWidth ? 'w-full' : ''}>
      <div 
        class="lightgallery-component" 
        data-options={JSON.stringify({ thumbnail: false, download: false })}
      >
        <a href={highResSrc} data-lg-id="true" aria-label={alt ? `View ${alt}` : 'View image in full size'}>
          <img
            src={imgSrc}
            srcset={srcsetString}
            alt={alt}
            loading="lazy"
            decoding="async"
            class={`rounded-lg h-auto hover:opacity-90 transition-opacity cursor-zoom-in ${fullWidth ? 'w-full' : 'max-w-full'}`}
            sizes={sizes || '(min-width: 35em) 1200px, 100vw'}
            {...(resolvedWidth && { width: resolvedWidth })}
            {...(resolvedHeight && { height: resolvedHeight })}
          />
        </a>
      </div>
    </div>
  ) : link ? (
    <a href={link} target="_blank" rel="noopener noreferrer" class={fullWidth ? 'w-full' : ''} aria-label={alt ? `${alt} (opens in new tab)` : 'View image (opens in new tab)'}>
      <img
        src={imgSrc}
        srcset={srcsetString}
        alt={alt}
        loading="lazy"
        decoding="async"
        class={`rounded-lg h-auto hover:opacity-90 transition-opacity ${fullWidth ? 'w-full' : 'max-w-full'}`}
        sizes={sizes || '(min-width: 35em) 1200px, 100vw'}
        {...(resolvedWidth && { width: resolvedWidth })}
        {...(resolvedHeight && { height: resolvedHeight })}
      />
    </a>
  ) : (
    <img
      src={imgSrc}
      srcset={srcsetString}
      alt={alt}
      loading="lazy"
      decoding="async"
      class={`rounded-lg h-auto ${fullWidth ? 'w-full' : 'max-w-full'}`}
      sizes={sizes || '(min-width: 35em) 1200px, 100vw'}
      {...(resolvedWidth && { width: resolvedWidth })}
      {...(resolvedHeight && { height: resolvedHeight })}
    />
  )}
</div>
