---
import type { HTMLAttributes } from 'astro/types';
import { Icon } from 'astro-icon/components';

type BaseVariant = 'note' | 'tip' | 'important' | 'caution' | 'warning';

export type CalloutVariant = BaseVariant | 'general' | 'info';

export interface CalloutProps extends HTMLAttributes<'aside'> {
  /** Choose from the supported callout variants */
  variant?: CalloutVariant;
  /** Optional heading shown above the content. Defaults to the variant label. */
  title?: string;
  /** Override the default icon. Pass an Iconify name (e.g. fe:info) or fallback text/emoji. */
  icon?: string;
}

const {
  variant = 'general',
  title,
  icon,
  class: className,
  ...rest
} = Astro.props as CalloutProps;

const variants: Record<BaseVariant, { label: string; iconName: string }> = {
  note: { label: 'Note', iconName: 'tabler:info-circle' },
  tip: { label: 'Tip', iconName: 'tabler:bulb' },
  important: { label: 'Important', iconName: 'tabler:alert-circle' },
  caution: { label: 'Caution', iconName: 'tabler:circle-x' },
  warning: { label: 'Warning', iconName: 'tabler:alert-triangle' },
};

const variantKey: BaseVariant = (() => {
  if (variant === 'general' || variant === 'info') return 'note';
  return variant as BaseVariant;
})();

const current = variants[variantKey];
const label = title ?? (() => {
  if (variant === 'general') return 'General';
  if (variant === 'info') return 'Info';
  return current.label;
})();
const resolvedIcon = icon ?? current.iconName;
const isIconName = resolvedIcon.includes(':');
---

<aside
  {...rest}
  role="note"
  aria-label={label}
  class:list={['callout', `callout-${variantKey}`, className]}
>
  <div class="flex flex-col gap-1.5">
    <div class="callout-heading flex items-center gap-2">
      {isIconName ? (
        <Icon
          name={resolvedIcon}
          class="h-4 w-4 shrink-0"
          aria-hidden="true"
        />
      ) : (
        <span class="text-sm font-semibold">
          {resolvedIcon}
        </span>
      )}
      {label && <span>{label}</span>}
    </div>
    <div class="callout-content not-prose text-base leading-relaxed">
      <slot />
    </div>
  </div>
</aside>

<style is:global>
  .callout-content > :first-child {
    margin-top: 0 !important;
  }

  .callout-content > :last-child {
    margin-bottom: 0 !important;
  }
</style>
