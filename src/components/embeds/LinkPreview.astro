---
import { getLinkPreviewData, getLinkPreviewImage, getLinkPreviewSrcSet, isFaviconImage } from '../../utils/link-preview';

interface Props {
  id: string;
  hideMedia?: boolean;
}

const { id, hideMedia } = Astro.props;

// Get cached data (downloaded at build time by cache-link-preview-images.js)
const cachedData = getLinkPreviewData(id);

// Determine image source: prefer local cached image with CF transformations
const localImage = getLinkPreviewImage(id);
const srcSet = getLinkPreviewSrcSet(id);
const imageUrl = localImage || cachedData?.originalImage || null;
const imageAlt = cachedData?.imageAlt || cachedData?.title || '';
const isFavicon = isFaviconImage(id);

// Extract domain for display
const domain = (() => {
  try {
    return new URL(id).hostname.replace(/^www\./, '');
  } catch {
    return id;
  }
})();

const title = cachedData?.title || domain;
const description = cachedData?.description || '';
const linkUrl = id;
---

<div class="link-preview-card my-6 rounded-xl overflow-hidden">
  <a
    href={linkUrl}
    target="_blank"
    rel="noopener noreferrer"
    class="link-preview flex flex-col-reverse sm:flex-row items-stretch no-underline text-inherit hover:no-underline"
  >
    <div class="flex-1 p-4 flex flex-col justify-center min-w-0">
      <div class="link-preview-title font-bold line-clamp-2 flex items-center gap-2">
        {isFavicon && imageUrl && (
          <img
            src={imageUrl}
            alt=""
            width="20"
            height="20"
            loading="lazy"
            decoding="async"
            class="w-5 h-5 object-contain flex-shrink-0"
          />
        )}
        {title}
      </div>
      {description && (
        <div class="link-preview-description mt-1 text-sm line-clamp-2">
          {description}
        </div>
      )}
      <div class="link-preview-domain mt-2 text-xs">
        {domain}
      </div>
    </div>
    {!hideMedia && imageUrl && !isFavicon && (
      <div class="link-preview-image relative aspect-[1200/630] sm:aspect-auto sm:flex-[0_0_35%]">
        <img
          src={imageUrl}
          srcset={srcSet || undefined}
          sizes="(max-width: 640px) 100vw, 35vw"
          alt={imageAlt}
          width="1200"
          height="630"
          loading="lazy"
          decoding="async"
          class="sm:absolute sm:inset-0 h-full w-full object-cover !m-0"
        />
      </div>
    )}
  </a>
</div>

<style>
  .link-preview-card {
    border: 1px solid var(--color-outline-variant, rgba(25, 28, 29, 0.2));
    background: var(--color-surface-container-lowest, #ffffff);
    box-shadow: var(--shadow-ambient, 0 8px 24px rgba(25, 28, 29, 0.05));
    transition: box-shadow 0.2s ease;
  }

  .link-preview-card:hover {
    box-shadow: var(--shadow-ambient-hover, 0 12px 32px rgba(25, 28, 29, 0.08));
  }

  .link-preview {
    width: 100% !important;
    max-width: 100% !important;
    text-decoration: none !important;
    display: flex !important;
    min-height: 0;
  }

  .link-preview:hover {
    text-decoration: none !important;
  }

  .link-preview-image {
    display: flex;
    min-height: 100%;
  }

  .link-preview-image img {
    margin: 0 !important;
    aspect-ratio: auto !important;
    height: 100% !important;
    max-width: none !important;
    box-shadow: none !important;
    border-radius: 0 !important;
  }

  .link-preview-title {
    color: var(--color-on-surface, #191c1d);
    font-size: 1rem;
    line-height: 1.4;
  }

  .link-preview:hover .link-preview-title {
    color: var(--color-primary, #00288e);
  }

  .link-preview-description {
    color: var(--color-on-surface-variant, #44474f);
    line-height: 1.5;
  }

  .link-preview-domain {
    color: var(--color-on-surface-variant, #44474f);
    opacity: 0.6;
  }
</style>