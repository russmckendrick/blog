---
import { getTagUrl, getTagDisplayName, getTagColorClasses } from '../../utils/tags';

interface Props {
	tags: string[];
	class?: string;
}

const { tags, class: className = '' } = Astro.props;
---

<nav aria-label="Category navigation" class={`flex flex-wrap justify-center gap-x-5 gap-y-3 ${className}`}>
	{tags.map((tag, index) => (
		<>
			{index > 0 && <span aria-hidden="true" class="text-on-surface-variant">&middot;</span>}
			<a href={getTagUrl(tag)} class={getTagColorClasses(tag)}>
				{getTagDisplayName(tag)}
			</a>
		</>
	))}
</nav>
