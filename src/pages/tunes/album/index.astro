---
import BaseLayout from '../../../layouts/BaseLayout.astro'
import { tunesIndex, getAlbumTuneUrl } from '../../../utils/tunes-index'
import TunesDirectory from '../../../components/tunes/TunesDirectory.astro'
import { Schema } from 'astro-seo-schema'
import { createCollectionPageSchema, createBreadcrumbSchema } from '../../../utils/schema'

const siteUrl = Astro.site?.toString() || 'https://www.russ.cloud/'
const pageUrl = new URL(Astro.url.pathname, Astro.site).toString()

const albums = tunesIndex.albums.slice().sort((a, b) =>
  a.name.localeCompare(b.name, 'en', { sensitivity: 'base' })
)

const pluralize = (count: number, singular: string) =>
  `${count} ${singular}${count === 1 ? '' : 's'}`

const getDirectoryBucket = (name: string) => {
  const firstChar = name.replace(/^the\s+/i, '').trim().charAt(0).toUpperCase()
  return /[A-Z]/.test(firstChar) ? firstChar : '#'
}

const groups = new Map<string, Array<{
  href: string
  name: string
  image: string | null
  imageAlt: string
  kicker: string
  meta: string
}>>()

for (const album of albums) {
  const bucket = getDirectoryBucket(album.name)
  if (!groups.has(bucket)) groups.set(bucket, [])
  groups.get(bucket)!.push({
    href: getAlbumTuneUrl(album.slug),
    name: album.name,
    image: album.image,
    imageAlt: `${album.name} by ${album.artist}`,
    kicker: album.artist,
    meta: pluralize(album.posts.length, 'post')
  })
}

const orderedGroups = Array.from(groups.entries()).sort(([a], [b]) => a.localeCompare(b))

const title = 'Albums I have listened to ...'
const description = `Every record featured in the weekly Listened to This Week series on russ.cloud - ${albums.length} albums by ${tunesIndex.totals.artists} artists, sorted A to Z.`

const collectionSchema = createCollectionPageSchema({
  name: title,
  description,
  url: pageUrl,
  items: albums.slice(0, 100).map((album) => ({
    name: `${album.name} - ${album.artist}`,
    url: new URL(getAlbumTuneUrl(album.slug), siteUrl).toString()
  })),
  numberOfItems: albums.length
})

const breadcrumbSchema = createBreadcrumbSchema(
  [
    { name: 'Home', url: '/' },
    { name: 'Tunes', url: '/tunes/' },
    { name: 'Albums', url: '/tunes/album/' }
  ],
  siteUrl
)
---

<BaseLayout title={title} description={description}>
  <Schema slot="head" item={collectionSchema} />
  <Schema slot="head" item={breadcrumbSchema} />

  <section class="surface-container-low text-center py-12 pb-16 mb-8">
    <div class="max-w-3xl mx-auto px-5 animate-fade-in">
      <p class="text-sm uppercase tracking-wide text-on-surface-variant mb-2">
        <a href="/tunes/" class="hover:text-[var(--color-secondary)] transition-colors">Tunes</a>
        <span aria-hidden="true"> · </span>
        Albums
      </p>
      <h1 class="text-4xl lg:text-5xl font-bold mb-4 text-on-surface font-display">
        {title} 💿
      </h1>
      <p class="text-lg text-on-surface-variant">
        {albums.length} albums covered across {tunesIndex.totals.posts} weekly posts.
      </p>
    </div>
  </section>

  <section class="max-w-7xl mx-auto px-5 pb-12">
    <TunesDirectory groups={orderedGroups} />
  </section>
</BaseLayout>
