---
import { getCollection } from 'astro:content'
import type { CollectionEntry } from 'astro:content'
import type { GetStaticPaths } from 'astro'
import BaseLayout from '../../../layouts/BaseLayout.astro'
import PostCard from '../../../components/blog/PostCard.astro'
import { Schema } from 'astro-seo-schema'
import {
  tunesIndex,
  getAlbumBySlug,
  getArtistTuneUrl,
  getAlbumTuneUrl
} from '../../../utils/tunes-index'
import {
  createMusicAlbumSchema,
  createBreadcrumbSchema
} from '../../../utils/schema'

export const getStaticPaths = (async () => {
  return tunesIndex.albums.map((album) => ({ params: { album: album.slug } }))
}) satisfies GetStaticPaths

const { album: albumSlug } = Astro.params
const album = getAlbumBySlug(albumSlug!)
if (!album) {
  return new Response(null, { status: 404, statusText: 'Album not found' })
}

const allTunes = await getCollection('tunes')
const postUrls = new Set(album.posts.map((p) => p.url))
const featureTunes = allTunes
  .filter((tune) => {
    const date = tune.data.pubDate
    const year = date.getFullYear().toString()
    const month = String(date.getMonth() + 1).padStart(2, '0')
    const day = String(date.getDate()).padStart(2, '0')
    const slug = tune.data.title
      .toLowerCase()
      .replace(/[^a-z0-9\s-]/g, '')
      .replace(/\s+/g, '-')
      .replace(/-+/g, '-')
      .trim()
      .replace(/^-+|-+$/g, '')
    return postUrls.has(`/${year}/${month}/${day}/${slug}/`)
  })
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())

const siteUrl = Astro.site?.toString() || 'https://www.russ.cloud/'
const pageUrl = new URL(Astro.url.pathname, Astro.site).toString()

const title = `${album.name} - ${album.artist}`
const featuredCount = album.posts.length
const description = `${album.name} by ${album.artist} appears in ${featuredCount} weekly Listened to This Week post${
  featuredCount !== 1 ? 's' : ''
} on russ.cloud. See when it landed in rotation, what else was on the turntable that week, and links to the original write-ups.`

const musicSchema = createMusicAlbumSchema({
  name: album.name,
  byArtist: album.artist,
  url: pageUrl,
  image: album.image ? new URL(album.image, siteUrl).toString() : undefined,
  description
})

const breadcrumbSchema = createBreadcrumbSchema(
  [
    { name: 'Home', url: '/' },
    { name: 'Tunes', url: '/tunes/' },
    { name: 'Albums', url: '/tunes/album/' },
    { name: album.name, url: getAlbumTuneUrl(album.slug) }
  ],
  siteUrl
)
---

<BaseLayout title={title} description={description} image={`/tunes/album/${album.slug}-og.png`}>
  <Schema slot="head" item={musicSchema} />
  <Schema slot="head" item={breadcrumbSchema} />

  <section class="surface-container-low py-8 pb-10 mb-8">
    <div class="max-w-5xl mx-auto px-5">
      <div class="text-center mb-4 animate-fade-in">
        <a
          href="/tunes/album/"
          class="inline-flex items-center text-sm text-on-surface-variant hover:text-[var(--color-secondary)] transition-colors"
        >
          <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
          </svg>
          All albums
        </a>
      </div>

      <div class="text-center animate-fade-in animate-delay-1">
        <h1 class="text-3xl lg:text-5xl font-bold text-on-surface font-display mb-3">
          {album.name} 💿
        </h1>
        <p class="text-lg text-on-surface-variant">
          by{' '}
          <a class="text-[var(--color-secondary)] hover:underline" href={getArtistTuneUrl(album.artistSlug)}>
            {album.artist}
          </a>
        </p>
        <p class="text-sm text-on-surface-variant mt-2">
          Featured in {featuredCount} weekly post{featuredCount !== 1 ? 's' : ''}
        </p>
        {album.albumUrl && (
          <p class="text-sm text-on-surface-variant mt-3">
            More on the music site:
            {' '}<a class="text-[var(--color-secondary)] hover:underline" href={album.albumUrl} rel="noopener noreferrer" target="_blank">{album.albumUrl.replace(/^https?:\/\//, '')}</a>
          </p>
        )}
      </div>
    </div>
  </section>

  <section class="max-w-7xl mx-auto px-5">
    <h2 class="sr-only">Posts that featured {album.name}</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5 lg:gap-6 items-stretch reveal-stagger">
      {featureTunes.map((tune: CollectionEntry<'tunes'>) => (
        <div class="reveal">
          <PostCard post={tune} variant="grid" />
        </div>
      ))}
    </div>
  </section>
</BaseLayout>
