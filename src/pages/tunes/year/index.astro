---
import { getCollection } from 'astro:content'
import BaseLayout from '../../../layouts/BaseLayout.astro'
import { Schema } from 'astro-seo-schema'
import { createCollectionPageSchema, createBreadcrumbSchema } from '../../../utils/schema'

const tunes = (await getCollection('tunes'))
  .filter((tune) => import.meta.env.DEV || !tune.data.draft)

const counts = new Map<number, number>()
for (const tune of tunes) {
  const year = tune.data.pubDate.getFullYear()
  counts.set(year, (counts.get(year) || 0) + 1)
}

const years = Array.from(counts.entries())
  .sort(([a], [b]) => b - a)
  .map(([year, count]) => ({ year, count }))

const siteUrl = Astro.site?.toString() || 'https://www.russ.cloud/'
const pageUrl = new URL(Astro.url.pathname, Astro.site).toString()

const title = 'Tunes by year'
const description = `Browse weekly Listened to This Week posts by calendar year - ${years.length} year${years.length !== 1 ? 's' : ''} of music journals on russ.cloud.`

const collectionSchema = createCollectionPageSchema({
  name: title,
  description,
  url: pageUrl,
  items: years.map(({ year }) => ({
    name: String(year),
    url: new URL(`/tunes/year/${year}/`, siteUrl).toString()
  })),
  numberOfItems: years.length
})

const breadcrumbSchema = createBreadcrumbSchema(
  [
    { name: 'Home', url: '/' },
    { name: 'Tunes', url: '/tunes/' },
    { name: 'Years', url: '/tunes/year/' }
  ],
  siteUrl
)
---

<BaseLayout title={title} description={description}>
  <Schema slot="head" item={collectionSchema} />
  <Schema slot="head" item={breadcrumbSchema} />

  <section class="surface-container-low text-center py-12 pb-16 mb-8">
    <div class="max-w-3xl mx-auto px-5 animate-fade-in">
      <p class="text-sm uppercase tracking-wide text-on-surface-variant mb-2">Tunes</p>
      <h1 class="text-4xl lg:text-5xl font-bold mb-4 text-on-surface font-display">
        By year
      </h1>
      <p class="text-lg text-on-surface-variant">
        {years.length} year{years.length !== 1 ? 's' : ''} of weekly music journals.
      </p>
    </div>
  </section>

  <section class="max-w-3xl mx-auto px-5 pb-16">
    <ul class="grid grid-cols-1 sm:grid-cols-2 gap-x-8">
      {years.map(({ year, count }) => (
        <li class="border-b" style="border-color: var(--color-outline-variant);">
          <a
            href={`/tunes/year/${year}/`}
            class="group flex items-baseline justify-between gap-3 py-3 no-underline"
          >
            <span class="font-display text-lg text-on-surface transition-colors group-hover:text-[var(--color-secondary)]" style="font-weight: 540;">{year}</span>
            <span class="rubric">{count} post{count !== 1 ? 's' : ''}</span>
          </a>
        </li>
      ))}
    </ul>
  </section>
</BaseLayout>
