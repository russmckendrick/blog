---
import { getCollection } from 'astro:content'
import type { CollectionEntry } from 'astro:content'
import type { GetStaticPaths } from 'astro'
import BaseLayout from '../../../../layouts/BaseLayout.astro'
import PostCard from '../../../../components/blog/PostCard.astro'
import { Schema } from 'astro-seo-schema'
import { createCollectionPageSchema, createBreadcrumbSchema } from '../../../../utils/schema'
import { createUrlFriendlySlug } from '../../../../utils/url'

export const getStaticPaths = (async () => {
  const tunes = (await getCollection('tunes'))
    .filter((tune) => import.meta.env.DEV || !tune.data.draft)

  const years = new Set<number>()
  for (const tune of tunes) {
    years.add(tune.data.pubDate.getFullYear())
  }

  return Array.from(years).map((year) => ({
    params: { year: String(year) }
  }))
}) satisfies GetStaticPaths

const { year: yearParam } = Astro.params
const year = Number(yearParam)

const allTunes = (await getCollection('tunes'))
  .filter((tune) => import.meta.env.DEV || !tune.data.draft)

const yearTunes = allTunes
  .filter((tune) => tune.data.pubDate.getFullYear() === year)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())

// Year-in-music essay, if one exists for this year. Detected by filename slug.
const wrappedEntry = yearTunes.find((tune) => tune.id === `${year}-year-in-music`)
const weeklyTunes = wrappedEntry ? yearTunes.filter((tune) => tune.id !== wrappedEntry.id) : yearTunes

const wrappedHref = wrappedEntry
  ? (() => {
      const date = wrappedEntry.data.pubDate
      const month = String(date.getMonth() + 1).padStart(2, '0')
      const day = String(date.getDate()).padStart(2, '0')
      return `/${year}/${month}/${day}/${createUrlFriendlySlug(wrappedEntry.data.title)}/`
    })()
  : null

const siteUrl = Astro.site?.toString() || 'https://www.russ.cloud/'
const pageUrl = new URL(Astro.url.pathname, Astro.site).toString()

const title = `Tunes ${year}`
const description = wrappedEntry
  ? `${wrappedEntry.data.description} Plus the ${weeklyTunes.length} weekly Listened to This Week posts from ${year}.`
  : `${weeklyTunes.length} weekly Listened to This Week post${weeklyTunes.length !== 1 ? 's' : ''} from ${year} on russ.cloud.`

const collectionSchema = createCollectionPageSchema({
  name: title,
  description,
  url: pageUrl,
  items: weeklyTunes.map((tune) => {
    const date = tune.data.pubDate
    const month = String(date.getMonth() + 1).padStart(2, '0')
    const day = String(date.getDate()).padStart(2, '0')
    const slug = createUrlFriendlySlug(tune.data.title)
    return {
      name: tune.data.title,
      url: new URL(`/${year}/${month}/${day}/${slug}/`, siteUrl).toString()
    }
  }),
  numberOfItems: weeklyTunes.length
})

const breadcrumbSchema = createBreadcrumbSchema(
  [
    { name: 'Home', url: '/' },
    { name: 'Tunes', url: '/tunes/' },
    { name: 'Years', url: '/tunes/year/' },
    { name: String(year), url: `/tunes/year/${year}/` }
  ],
  siteUrl
)
---

<BaseLayout title={title} description={description} image={`/tunes/year/${year}-og.png`}>
  <Schema slot="head" item={collectionSchema} />
  <Schema slot="head" item={breadcrumbSchema} />

  <section class="surface-container-low py-8 pb-10 mb-8">
    <div class="max-w-5xl mx-auto px-5">
      <div class="text-center mb-4 animate-fade-in">
        <a
          href="/tunes/year/"
          class="inline-flex items-center text-sm text-on-surface-variant hover:text-[var(--color-secondary)] transition-colors"
        >
          <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
          </svg>
          All years
        </a>
      </div>

      <div class="text-center animate-fade-in animate-delay-1">
        <p class="text-sm uppercase tracking-wide text-on-surface-variant mb-2">Tunes</p>
        <h1 class="text-3xl lg:text-5xl font-bold text-on-surface font-display mb-3">
          {year} 📅
        </h1>
        <p class="text-base text-on-surface-variant max-w-3xl mx-auto">
          {weeklyTunes.length} weekly post{weeklyTunes.length !== 1 ? 's' : ''}{wrappedEntry ? ' plus a year-in-review essay' : ''}.
        </p>
      </div>
    </div>
  </section>

  {wrappedEntry && wrappedHref && (
    <section class="max-w-3xl mx-auto px-5 mb-12">
      <a
        href={wrappedHref}
        class="group block py-5 border-t-2 border-b no-underline"
        style="border-top-color: var(--rule-strong); border-bottom-color: var(--color-outline-variant);"
      >
        <p class="rubric mb-2" style="color: var(--color-secondary);">Year in review</p>
        <h2 class="font-display text-2xl text-on-surface mb-2 transition-colors group-hover:text-[var(--color-secondary)]" style="font-weight: 660;">
          {wrappedEntry.data.title}
        </h2>
        <p class="text-on-surface-variant">
          {wrappedEntry.data.description}
        </p>
        <p class="rubric mt-3">Read the full essay &rarr;</p>
      </a>
    </section>
  )}

  <section class="max-w-7xl mx-auto px-5 pb-16">
    <h2 class="font-display text-xl font-semibold text-on-surface mb-4">
      Weekly posts from {year}
    </h2>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5 lg:gap-6 items-stretch reveal-stagger">
      {weeklyTunes.map((tune: CollectionEntry<'tunes'>) => (
        <div class="reveal">
          <PostCard post={tune} variant="grid" headingLevel="3" />
        </div>
      ))}
    </div>
  </section>
</BaseLayout>
