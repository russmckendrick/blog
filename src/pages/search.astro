---
import BaseLayout from '../layouts/BaseLayout.astro';
import PagefindSearch from 'astro-pagefind/components/Search';

const isDev = import.meta.env.DEV;
---

<BaseLayout title="Search" description="Search Russ.Cloud blog posts and content">
	<div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
		<section class="pt-4 pb-10 border-b-2" style="border-color: var(--rule-strong);">
			<p class="rubric mb-3" data-entrance>The Index</p>
			<h1 class="mb-2 text-4xl lg:text-5xl text-on-surface" data-entrance>
				Search
			</h1>
			<p class="text-lg text-on-surface-variant" data-entrance>
				Find articles, tutorials, and insights
			</p>
		</section>

		{isDev && (
			<div class="callout callout-warning mt-6">
				<p class="callout-heading">Development Mode</p>
				<p>
					Search requires a production build to index content. Run{' '}
					<code>npm run build</code>{' '}
					and{' '}
					<code>npm run preview</code>{' '}
					to test search functionality.
				</p>
			</div>
		)}

		<section class="py-6 md:py-8">
			<PagefindSearch
				id="search"
				className="pagefind-ui"
				uiOptions={{ showImages: false, excerptLength: 15 }}
			/>
		</section>
	</div>
</BaseLayout>

<script>
	// Reinitialize Pagefind after View Transitions navigation
	function initPagefind() {
		const searchElement = document.querySelector('.pagefind-ui');
		if (searchElement && window.PagefindUI) {
			// Clear existing content
			searchElement.innerHTML = '';
			// Reinitialize
			new window.PagefindUI({
				element: searchElement,
				showImages: false,
				excerptLength: 15
			});
		}
	}

	// Initialize on first load
	initPagefind();

	// Re-initialize after View Transitions navigation
	document.addEventListener('astro:page-load', initPagefind);

	// Track search usage as a Plausible goal (debounced, query not sent for privacy).
	// Delegated so it survives Pagefind re-initialisation and View Transitions.
	let searchTimer: ReturnType<typeof setTimeout>;
	document.addEventListener('input', (e) => {
		const target = e.target as HTMLElement;
		if (!target.classList.contains('pagefind-ui__search-input')) return;
		clearTimeout(searchTimer);
		searchTimer = setTimeout(() => {
			if ((target as HTMLInputElement).value.trim().length >= 2) {
				window.plausible?.('Search', { interactive: false });
			}
		}, 1200);
	});
</script>

<style is:global>
	/* Pagefind UI Theme Variables - paper and ink (light) */
	:root {
		--pagefind-ui-scale: 1;
		--pagefind-ui-primary: #1f1c17;
		--pagefind-ui-text: #5a5348;
		--pagefind-ui-background: #fbf8f1;
		--pagefind-ui-border: rgba(31, 28, 23, 0.18);
		--pagefind-ui-tag: #e9e2d2;
		--pagefind-ui-border-radius: 0;
		--pagefind-ui-font: var(--font-serif), Georgia, serif;
	}

	/* Pagefind UI Theme Variables - ink and paper (dark) */
	.dark {
		--pagefind-ui-primary: #e9e2d2;
		--pagefind-ui-text: #b5ac97;
		--pagefind-ui-background: #100e0a;
		--pagefind-ui-border: rgba(233, 226, 210, 0.16);
		--pagefind-ui-tag: #221e16;
	}

	/* Square everything the vars don't reach */
	.pagefind-ui__search-input,
	.pagefind-ui__search-clear,
	.pagefind-ui__button,
	.pagefind-ui__result-thumb,
	.pagefind-ui__result-tag {
		border-radius: 0 !important;
	}

	/* Search Input Focus States */
	.pagefind-ui__search-input {
		transition: border-color 0.2s ease, box-shadow 0.2s ease;
	}

	.pagefind-ui__search-input:focus {
		border-color: var(--color-secondary) !important;
		box-shadow: none;
		outline: 2px solid var(--color-secondary);
		outline-offset: 2px;
	}

	/* Result Link Hover Effects */
	.pagefind-ui__result-link {
		transition: color 0.15s ease;
	}

	.pagefind-ui__result-link:hover {
		color: var(--color-secondary) !important;
	}

	/* Search Term Highlight Styling */
	.pagefind-ui mark {
		background-color: color-mix(in srgb, var(--accent-highlight) 25%, transparent);
		color: inherit;
		padding: 0.1em 0.2em;
		border-radius: 0;
	}

	/* Clear Button Styling */
	.pagefind-ui__search-clear {
		transition: color 0.15s ease;
	}

	.pagefind-ui__search-clear:hover {
		color: var(--color-on-surface) !important;
	}

	/* Load More Button Styling */
	.pagefind-ui__button {
		transition: border-color 0.2s ease, background-color 0.2s ease, color 0.2s ease;
	}

	.pagefind-ui__button:hover {
		border-color: var(--color-secondary) !important;
		color: var(--color-secondary) !important;
	}

	/* Mobile Responsive Adjustments */
	@media (max-width: 640px) {
		.pagefind-ui__search-input {
			font-size: calc(18px * var(--pagefind-ui-scale)) !important;
			height: calc(56px * var(--pagefind-ui-scale)) !important;
		}

		.pagefind-ui__result-title {
			font-size: calc(18px * var(--pagefind-ui-scale)) !important;
		}

		.pagefind-ui__result-excerpt {
			font-size: calc(14px * var(--pagefind-ui-scale)) !important;
		}
	}
</style>
