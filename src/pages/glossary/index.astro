---
import { getCollection } from 'astro:content'
import BaseLayout from '../../layouts/BaseLayout.astro'
import { Schema } from 'astro-seo-schema'
import { createCollectionPageSchema, createBreadcrumbSchema } from '../../utils/schema'

const entries = (await getCollection('glossary'))
  .filter((entry) => import.meta.env.DEV || !entry.data.draft)
  .sort((a, b) => a.data.term.localeCompare(b.data.term, 'en', { sensitivity: 'base' }))

const groups = new Map<string, typeof entries>()
for (const entry of entries) {
  const letter = entry.data.term.charAt(0).toUpperCase()
  const bucket = /[A-Z]/.test(letter) ? letter : '#'
  if (!groups.has(bucket)) groups.set(bucket, [])
  groups.get(bucket)!.push(entry)
}
const orderedGroups = Array.from(groups.entries()).sort(([a], [b]) => a.localeCompare(b))

const siteUrl = Astro.site?.toString() || 'https://www.russ.cloud/'
const pageUrl = new URL(Astro.url.pathname, Astro.site).toString()

const title = 'Technology glossary'
const description = `Plain-language definitions for the cloud, AI, automation, code, security, and tool terms that show up across russ.cloud - ${entries.length} entr${entries.length === 1 ? 'y' : 'ies'} and growing.`

const collectionSchema = createCollectionPageSchema({
  name: title,
  description,
  url: pageUrl,
  items: entries.map((entry) => ({
    name: entry.data.term,
    url: new URL(`/glossary/${entry.id}/`, siteUrl).toString()
  })),
  numberOfItems: entries.length
})

const breadcrumbSchema = createBreadcrumbSchema(
  [
    { name: 'Home', url: '/' },
    { name: 'Glossary', url: '/glossary/' }
  ],
  siteUrl
)
---

<BaseLayout title={title} description={description}>
  <Schema slot="head" item={collectionSchema} />
  <Schema slot="head" item={breadcrumbSchema} />

  <section class="max-w-4xl mx-auto px-5 pt-4 pb-10 mb-10 border-b-2" style="border-color: var(--rule-strong);">
    <p class="rubric mb-3" data-entrance>Reference</p>
    <h1 class="text-4xl lg:text-5xl mb-4 text-on-surface font-display" data-entrance>Technology glossary</h1>
    <p class="text-lg text-on-surface-variant" data-entrance>
      {description}
    </p>
  </section>

  <section class="max-w-4xl mx-auto px-5 pb-16">
    {orderedGroups.length > 1 && (
      <nav aria-label="Jump to letter" class="mb-10 pb-4 border-b flex flex-wrap gap-x-4 gap-y-2" style="border-color: var(--color-outline-variant);">
        {orderedGroups.map(([letter]) => (
          <a
            href={`#letter-${letter}`}
            class="rubric nav-underline no-underline hover:text-on-surface"
          >
            {letter}
          </a>
        ))}
      </nav>
    )}

    {orderedGroups.map(([letter, list]) => (
      <section id={`letter-${letter}`} class="mb-12 scroll-mt-24">
        <h2 class="font-display text-3xl mb-2 pb-2 border-b text-on-surface" style="border-color: var(--color-outline-variant);">{letter}</h2>
        <ul>
          {list.map((entry) => (
            <li class="border-b last:border-b-0" style="border-color: var(--color-outline-variant);">
              <a href={`/glossary/${entry.id}/`} class="group block py-4 no-underline">
                <h3 class="font-display text-xl text-on-surface transition-colors group-hover:text-[var(--color-secondary)]" style="font-weight: 540;">
                  {entry.data.term}
                  {entry.data.abbreviation && (
                    <span class="ml-2 text-sm font-normal text-on-surface-variant">
                      ({entry.data.abbreviation})
                    </span>
                  )}
                </h3>
                <p class="mt-1 text-sm text-on-surface-variant leading-relaxed">
                  {entry.data.description}
                </p>
              </a>
            </li>
          ))}
        </ul>
      </section>
    ))}
  </section>
</BaseLayout>
