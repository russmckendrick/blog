---
import { getCollection } from 'astro:content'
import BaseLayout from '../../layouts/BaseLayout.astro'
import { Schema } from 'astro-seo-schema'
import {
  createBookSchema,
  createCollectionPageSchema,
  createBreadcrumbSchema
} from '../../utils/schema'
import { AUTHOR_NAME } from '../../consts'

const siteUrl = Astro.site?.toString() || 'https://www.russ.cloud/'
const pageUrl = new URL(Astro.url.pathname, Astro.site).toString()

const allBooks = await getCollection('books', ({ data }) => !data.draft)
const books = allBooks.sort((a, b) => a.data.order - b.data.order)

const title = `Books by ${AUTHOR_NAME}`
const description = `${books.length} technical books written or co-authored by ${AUTHOR_NAME}, covering Docker, Kubernetes, Ansible, Infrastructure as Code, and serverless on Packt Publishing and The New Stack.`

const collectionSchema = createCollectionPageSchema({
  name: title,
  description,
  url: pageUrl,
  items: books.map((book) => ({
    name: book.data.title,
    url: new URL(`/books/${book.id}/`, siteUrl).toString()
  })),
  numberOfItems: books.length
})

const breadcrumbSchema = createBreadcrumbSchema(
  [
    { name: 'Home', url: '/' },
    { name: 'Books', url: '/books/' }
  ],
  siteUrl
)

const bookSchemas = books.map((book) =>
  createBookSchema({
    name: book.data.title,
    author: AUTHOR_NAME,
    url: new URL(`/books/${book.id}/`, siteUrl).toString(),
    image: new URL(book.data.cover, siteUrl).toString(),
    sameAs: book.data.buyLink ? [book.data.buyLink] : undefined,
    publisher: book.data.publisher
  })
)
---

<BaseLayout title={title} description={description}>
  <Schema slot="head" item={collectionSchema} />
  <Schema slot="head" item={breadcrumbSchema} />
  {bookSchemas.map((schema) => (
    <Schema slot="head" item={schema} />
  ))}

  <section class="max-w-6xl mx-auto px-5 pt-4 pb-10 mb-10 border-b-2" style="border-color: var(--rule-strong);">
    <p class="rubric mb-3" data-entrance>Bookshelf</p>
    <h1 class="text-4xl lg:text-5xl mb-4 text-on-surface font-display" data-entrance>
      Books by {AUTHOR_NAME}
    </h1>
    <p class="text-lg text-on-surface-variant max-w-3xl" data-entrance>
      {books.length} technical books on Docker, Kubernetes, Ansible, and Infrastructure as Code, mostly published by{' '}
      <a class="text-[var(--color-secondary)] hover:underline" href="https://www.packtpub.com/" target="_blank" rel="noopener noreferrer">Packt Publishing</a>.
    </p>
  </section>

  <section class="max-w-6xl mx-auto px-5 pb-16">
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-x-8 gap-y-10">
      {books.map((book) => (
        <a href={`/books/${book.id}/`} class="group block overflow-hidden" aria-label={book.data.title} data-reveal>
          <div class="border overflow-hidden aspect-[3/4]" style="border-color: var(--color-outline-variant);">
            <img src={book.data.cover} alt={book.data.alt} class="w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-[1.04]" loading="lazy" />
          </div>
        </a>
      ))}
    </div>

    <p class="text-sm text-on-surface-variant text-center mt-10">
      More on the author behind these books:{' '}
      <a class="text-[var(--color-secondary)] hover:underline" href="/about/">about page</a>{' '}·{' '}
      <a class="text-[var(--color-secondary)] hover:underline" href="/author/russ-mckendrick/">post archive</a>.
    </p>
  </section>
</BaseLayout>
