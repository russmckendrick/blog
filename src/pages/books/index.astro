---
import BaseLayout from '../../layouts/BaseLayout.astro'
import { Schema } from 'astro-seo-schema'
import {
  createBookSchema,
  createCollectionPageSchema,
  createBreadcrumbSchema
} from '../../utils/schema'
import { books } from '../../data/books'
import { AUTHOR_NAME } from '../../consts'

const siteUrl = Astro.site?.toString() || 'https://www.russ.cloud/'
const pageUrl = new URL(Astro.url.pathname, Astro.site).toString()

const title = `Books by ${AUTHOR_NAME}`
const description = `${books.length} technical books written or co-authored by ${AUTHOR_NAME}, covering Docker, Kubernetes, Ansible, Infrastructure as Code, and serverless on Packt Publishing and The New Stack.`

const collectionSchema = createCollectionPageSchema({
  name: title,
  description,
  url: pageUrl,
  items: books.map((book) => ({
    name: book.name,
    url: book.href ?? pageUrl
  })),
  numberOfItems: books.length
})

const breadcrumbSchema = createBreadcrumbSchema(
  [
    { name: 'Home', url: '/' },
    { name: 'Books', url: '/books/' }
  ],
  siteUrl
)

const bookSchemas = books.map((book) =>
  createBookSchema({
    name: book.name,
    author: AUTHOR_NAME,
    url: book.href ?? undefined,
    image: new URL(book.img, siteUrl).toString(),
    sameAs: book.href ? [book.href] : undefined,
    publisher: book.publisher
  })
)
---

<BaseLayout title={title} description={description}>
  <Schema slot="head" item={collectionSchema} />
  <Schema slot="head" item={breadcrumbSchema} />
  {bookSchemas.map((schema) => (
    <Schema slot="head" item={schema} />
  ))}

  <section class="surface-container-low text-center py-12 pb-16 mb-8">
    <div class="max-w-3xl mx-auto px-5 animate-fade-in">
      <p class="text-sm uppercase tracking-wide text-on-surface-variant mb-2">Bookshelf</p>
      <h1 class="text-4xl lg:text-5xl font-bold mb-4 text-on-surface font-display">
        Books by {AUTHOR_NAME}
      </h1>
      <p class="text-lg text-on-surface-variant">
        {books.length} technical books on Docker, Kubernetes, Ansible, and Infrastructure as Code, mostly published by{' '}
        <a class="text-[var(--color-secondary)] hover:underline" href="https://www.packtpub.com/" target="_blank" rel="noopener noreferrer">Packt Publishing</a>.
      </p>
    </div>
  </section>

  <section class="max-w-6xl mx-auto px-5 pb-16">
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-5 lg:gap-6 reveal-stagger">
      {books.map((book) => {
        const inner = (
          <div class="surface-container-lowest rounded-xl shadow-ambient ghost-border overflow-hidden aspect-[3/4] transition-all duration-300 hover:-translate-y-[3px] hover:shadow-[var(--shadow-ambient-hover)]">
            <img src={book.img} alt={book.alt} class="w-full h-full object-cover" loading="lazy" />
          </div>
        )
        return book.href ? (
          <a href={book.href} target="_blank" rel="noopener noreferrer" class="reveal" aria-label={book.name}>
            {inner}
          </a>
        ) : (
          <div class="reveal" aria-label={book.name}>
            {inner}
          </div>
        )
      })}
    </div>

    <p class="text-sm text-on-surface-variant text-center mt-10">
      More on the author behind these books:{' '}
      <a class="text-[var(--color-secondary)] hover:underline" href="/about/">about page</a>{' '}·{' '}
      <a class="text-[var(--color-secondary)] hover:underline" href="/author/russ-mckendrick/">post archive</a>.
    </p>
  </section>
</BaseLayout>
