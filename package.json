{
  "name": "russ-cloud",
  "type": "module",
  "version": "1.0.0",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20",
    "pnpm": ">=10"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build && node scripts/generate-llms-markdown.js",
    "preview": "astro preview",
    "astro": "astro",
    "post": "node scripts/new-post.js",
    "tunes": "node scripts/generate-tunes-post.js",
    "wrapped": "node scripts/generate-year-wrapped.js",
    "medium": "node scripts/publish-to-medium.js",
    "reading": "node scripts/fetch-reading-list.js",
    "reading-images": "node scripts/fetch-reading-list.js && node scripts/cache-reading-images.js --force --limit 3",
    "optimize": "node scripts/optimize-images.js",
    "analyze-links": "node scripts/analyze-internal-links.js",
    "extract-colors": "node scripts/extract-hero-colors.js",
    "prebuild": "pnpm run extract-colors && node scripts/cache-link-preview-images.js && node scripts/fetch-reading-list.js",
    "cache-link-previews": "node scripts/cache-link-preview-images.js",
    "refresh-link-previews": "node scripts/cache-link-preview-images.js --refresh-stale",
    "cache-reading-images": "node scripts/cache-reading-images.js",
    "refresh-reading-images": "node scripts/cache-reading-images.js --refresh-stale",
    "preinstall": "npx only-allow pnpm"
  },
  "dependencies": {
    "@astro-community/astro-embed-link-preview": "^0.3.1",
    "@astro-community/astro-embed-youtube": "^0.5.10",
    "@astrojs/check": "^0.9.9",
    "@astrojs/mdx": "^4.3.14",
    "@astrojs/react": "^5.0.4",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.2",
    "@casoon/astro-webvitals": "^0.2.1",
    "@fal-ai/client": "^1.10.0",
    "@felixicaza/astro-capo": "^1.0.1",
    "@iconify-json/tabler": "^1.2.33",
    "@langchain/langgraph": "^1.2.9",
    "@playform/compress": "0.2.1",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "astro": "^6.2.1",
    "astro-expressive-code": "^0.41.7",
    "astro-icon": "^1.1.5",
    "astro-lightgallery": "^2.4.0",
    "astro-pagefind": "^1.8.6",
    "astro-seo-plugin": "^1.3.5",
    "astro-seo-schema": "^5.2.0",
    "axios": "^1.15.2",
    "exa-js": "^2.12.1",
    "framer-motion": "^12.38.0",
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.1.1",
    "langchain": "^1.3.5",
    "lightgallery": "^2.9.0",
    "linkedom": "^0.18.12",
    "mermaid": "^11.14.0",
    "oauth-1.0a": "^2.2.6",
    "openai": "^6.35.0",
    "pagefind": "^1.5.2",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "sanitize-html": "^2.17.3",
    "satori": "^0.18.4",
    "schema-dts": "^1.1.5",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.2.4",
    "typescript": "^5.9.3",
    "unist-util-visit": "^5.1.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "workerd"
    ],
    "overrides": {
      "diff@<8.0.3": ">=8.0.3",
      "undici@>=7.0.0 <7.18.2": ">=7.18.2",
      "lodash-es@>=4.0.0 <=4.17.22": ">=4.17.23",
      "lodash@>=4.0.0 <=4.17.22": ">=4.17.23",
      "ajv@<8.18.0": ">=8.18.0",
      "devalue@<=5.6.2": ">=5.6.3",
      "minimatch@<10.2.1": ">=10.2.1",
      "svgo@=4.0.0": ">=4.0.1",
      "yauzl@<3.2.1": ">=3.2.1",
      "undici@>=7.0.0 <7.24.0": ">=7.24.0",
      "undici@>=7.17.0 <7.24.0": ">=7.24.0",
      "fast-xml-parser@>=4.0.0-beta.3 <=5.5.5": ">=5.5.6",
      "astro@>=2.10.10 <5.18.1": ">=5.18.1",
      "yaml@>=2.0.0 <2.8.3": ">=2.8.3",
      "lodash-es@>=4.0.0 <=4.17.23": ">=4.18.0",
      "lodash-es@<=4.17.23": ">=4.18.0",
      "fast-xml-parser@<5.7.0": ">=5.7.0",
      "uuid@<14.0.0": ">=14.0.0",
      "@anthropic-ai/sdk@>=0.79.0 <0.91.1": ">=0.91.1"
    }
  },
  "devDependencies": {
    "@langchain/anthropic": "^1.3.28",
    "@langchain/core": "^1.1.42",
    "@langchain/openai": "^1.4.5",
    "dotenv": "^17.4.2",
    "fast-glob": "^3.3.3",
    "puppeteer": "^24.42.0",
    "wrangler": "^4.87.0"
  }
}