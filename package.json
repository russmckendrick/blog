{
  "name": "russ-cloud",
  "type": "module",
  "version": "1.0.0",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20",
    "pnpm": ">=10"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build && node scripts/generate-llms-markdown.js",
    "preview": "astro preview",
    "astro": "astro",
    "post": "node scripts/new-post.js",
    "tunes": "node scripts/generate-tunes-post.js",
    "wrapped": "node scripts/generate-year-wrapped.js",
    "backfill-tunes-images": "node scripts/backfill-tunes-images.js",
    "medium": "node scripts/publish-to-medium.js",
    "reading": "node scripts/fetch-reading-list.js",
    "reading-images": "node scripts/fetch-reading-list.js && node scripts/cache-reading-images.js --force --limit 3",
    "optimize": "node scripts/optimize-images.js",
    "analyze-links": "node scripts/analyze-internal-links.js",
    "extract-colors": "node scripts/extract-hero-colors.js",
    "build-tunes-index": "node scripts/build-tunes-index.js",
    "prebuild": "pnpm run extract-colors && node scripts/cache-link-preview-images.js && node scripts/fetch-reading-list.js && node scripts/build-tunes-index.js",
    "cache-link-previews": "node scripts/cache-link-preview-images.js",
    "refresh-link-previews": "node scripts/cache-link-preview-images.js --refresh-stale",
    "cache-reading-images": "node scripts/cache-reading-images.js",
    "refresh-reading-images": "node scripts/cache-reading-images.js --refresh-stale",
    "preinstall": "npx only-allow pnpm"
  },
  "dependencies": {
    "@astro-community/astro-embed-link-preview": "^0.3.1",
    "@astro-community/astro-embed-youtube": "^0.5.10",
    "@astrojs/check": "^0.9.9",
    "@astrojs/mdx": "^6.0.3",
    "@astrojs/react": "^5.0.7",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.3",
    "@casoon/astro-webvitals": "^0.2.1",
    "@fal-ai/client": "^1.10.1",
    "@felixicaza/astro-capo": "^1.2.1",
    "@iconify-json/tabler": "^1.2.35",
    "@langchain/langgraph": "^1.4.4",
    "@tailwindcss/typography": "^0.5.20",
    "@tailwindcss/vite": "^4.3.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "astro": "^6.4.8",
    "astro-expressive-code": "^0.42.0",
    "astro-icon": "^1.1.5",
    "astro-lightgallery": "^2.6.0",
    "astro-pagefind": "^1.8.6",
    "astro-seo-plugin": "^1.3.7",
    "astro-seo-schema": "^5.2.0",
    "axios": "^1.18.0",
    "exa-js": "^2.14.0",
    "framer-motion": "^12.40.0",
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.2.0",
    "langchain": "^1.5.0",
    "lightgallery": "^2.9.0",
    "linkedom": "^0.18.12",
    "mermaid": "^11.15.0",
    "oauth-1.0a": "^2.2.6",
    "openai": "^6.44.0",
    "pagefind": "^1.5.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sanitize-html": "^2.17.5",
    "satori": "^0.18.4",
    "schema-dts": "^1.1.5",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.3.1",
    "typescript": "^5.9.3",
    "unist-util-visit": "^5.1.0"
  },
  "devDependencies": {
    "@astrojs/markdown-remark": "7.2.0",
    "@langchain/anthropic": "^1.5.0",
    "@langchain/core": "^1.2.0",
    "@langchain/openai": "^1.5.1",
    "dotenv": "^17.4.2",
    "fast-glob": "^3.3.3",
    "puppeteer": "^24.43.1",
    "wrangler": "^4.103.0"
  }
}
